# =============================================================================
# CyberSafe Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# =============================================================================
# REQUIRED - API Keys
# =============================================================================

# Groq API Key (for AI text analysis)
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Tavily API Key (for web search fallback in chatbot)
# Get your key from: https://tavily.com
TAVILY_API_KEY=your-tavily-api-key-here

# =============================================================================
# EMAIL CONFIGURATION (Optional but recommended)
# =============================================================================
# For OTP and notification emails

# Gmail Setup:
# 1. Enable 2-Step Verification at https://myaccount.google.com/security
# 2. Create App Password at https://myaccount.google.com/apppasswords
# 3. Use the 16-character app password below

EMAIL_ADDRESS=your.email@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Optional: Custom SMTP settings (defaults to Gmail)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# EMAIL_FROM_NAME=CyberSafe Portal

# =============================================================================
# DATABASE
# =============================================================================

# Path to SQLite database (inside container)
DB_PATH=/app/api/cybersafe.db

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Host and port for FastAPI
HOST=0.0.0.0
PORT=8000

# =============================================================================
# CORS Configuration
# =============================================================================
# Comma-separated list of allowed origins
# For local development:
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:8000

# For AWS EC2 (replace with your EC2 public IP or domain):
# CORS_ORIGINS=http://YOUR_EC2_PUBLIC_IP,http://YOUR_EC2_PUBLIC_IP:8000

# =============================================================================
# UPLOAD CONFIGURATION
# =============================================================================

UPLOAD_DIR=/app/api/uploads
MAX_FILE_SIZE_MB=50

# =============================================================================
# Groq LLM Model Configuration (fallbacks if primary fails)
# =============================================================================

GROQ_PRIMARY_MODEL=openai/gpt-oss-120b
GROQ_FALLBACK_MODEL=llama-3.1-70b-versatile
GROQ_SECONDARY_FALLBACK=mixtral-8x7b-32768
