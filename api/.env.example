# CyberSafe API Configuration
# Copy this file to .env and fill in your values

# ===== EMAIL CONFIGURATION =====
# Gmail SMTP (recommended for easy setup)
# 
# Steps to set up Gmail:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification
# 3. Go to App passwords (under 2-Step Verification)
# 4. Create a new app password for "Mail"
# 5. Copy the 16-character password below

EMAIL_ADDRESS=your.email@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Optional: Custom SMTP settings (defaults to Gmail)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# EMAIL_FROM_NAME=CyberSafe Portal

# ===== DATABASE =====
DB_PATH=./cybersafe.db

# ===== SERVER =====
HOST=0.0.0.0
PORT=8000

# ===== CORS (Frontend URLs allowed to access API) =====
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000

# ===== SECURITY =====
# Secret key for future JWT implementation (generate a random string)
# SECRET_KEY=your-super-secret-key-change-this

# ===== UPLOAD =====
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
